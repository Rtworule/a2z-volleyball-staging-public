{
  "name": "a-to-z-volleyball-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:demo": "vite --mode demo --host 127.0.0.1 --port 4173",
    "dev:local": "vite --mode development --host 127.0.0.1 --port 4173",
    "dev:staging": "vite --mode staging --host 127.0.0.1 --port 4173",
    "dev:production": "vite --mode production --host 127.0.0.1 --port 4173",
    "start": "npm run dev:local",
    "build": "vite build",
    "build:local": "vite build --mode development",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "node --test test/*.js features/*/test/*.js",
    "supabase:start": "supabase start --network-id supabase-local-a2z",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:push": "supabase db push"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0"
  }
}
